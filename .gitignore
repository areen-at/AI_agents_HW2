# ============================================================
#  SECRETS — never commit. Only .env.example is tracked.
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/
credentials.json
.gcm-connection.properties

# ============================================================
#  Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
*.egg-info/
.eggs/
*.egg
wheels/

# ============================================================
#  Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/
.python-version

# ============================================================
#  UV
# ============================================================
# uv.lock IS committed (reproducible builds) — do not ignore it.
.uv-cache/

# ============================================================
#  Test / coverage / type / lint caches
# ============================================================
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.cache/

# ============================================================
#  Logs & runtime artifacts (FIFO logger output)
# ============================================================
logs/
*.log
transcripts/
*.tmp

# ============================================================
#  Security tooling reports
# ============================================================
bandit-report.*
pip-audit-report.*
gitleaks-report.*

# ============================================================
#  IDE / editor
# ============================================================
.idea/
.vscode/
.vs/
*.swp
*.swo
*~

# ============================================================
#  OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
