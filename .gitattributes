# Normalize line endings: store text as LF in the repo, check out native.
* text=auto eol=lf

# Explicitly treat these as text.
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.cfg   text eol=lf
.env.example text eol=lf

# Binary assets — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
