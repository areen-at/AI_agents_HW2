# ============================================================
#  Environment template — copy to ".env" and fill in values.
#  NEVER commit ".env". Only this ".env.example" is tracked.
#    cp .env.example .env      (PowerShell: Copy-Item .env.example .env)
# ============================================================

# --- LLM providers ---------------------------------------------------
# Required when llm.provider = "anthropic" (default).
ANTHROPIC_API_KEY=

# Required only when llm.provider = "openai".
OPENAI_API_KEY=

# --- Web search tool (mandatory internet tool) -----------------------
# API key for the configured search.provider (see config.yaml).
SEARCH_API_KEY=
